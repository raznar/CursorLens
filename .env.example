# --- Required ---
# Secret used to encrypt API keys at rest in the local SQLite DB.
# Generate one with: openssl rand -hex 32
CURSOR_LENS_SECRET=

# --- API keys (optional here; can also be entered in the Settings UI) ---
# Cursor Admin/Analytics API key (Basic auth, admin:* scope). Used for data ingestion.
CURSOR_ADMIN_API_KEY=
# Cursor SDK key (user or team service-account key). Used by the Ask Agent.
# NOTE: team Admin API keys are NOT accepted by the SDK.
CURSOR_API_KEY=

# --- Optional configuration ---
# Where the SQLite DB + generated SCHEMA.md + query.mjs live (default: ./data)
DATA_DIR=./data

# Use bundled mock fixtures instead of calling the live Cursor API ("1" to enable).
# Lets you develop and run the full test suite without a live key.
CURSOR_MOCK=0

# Cursor API base URL (override only for testing).
CURSOR_API_BASE_URL=https://api.cursor.com

# Log level: trace | debug | info | warn | error
LOG_LEVEL=info
