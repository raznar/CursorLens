# Dependencies and build output (regenerated inside the image)
node_modules
.next
out
build

# Version control and CI
.git
.gitignore
.github

# Local SQLite database (created at runtime in the mounted volume)
data/*.db
data/*.db-shm
data/*.db-wal

# Env files / secrets — never bake these into the image
.env
.env.local
.env.*.local
*.pem

# Tests and coverage
coverage

# Agent/dev tooling not needed at runtime
.cursor
.husky

# Editor / OS cruft
.vscode
.idea
.DS_Store
*.log
npm-debug.log*

# Docker meta (not needed inside the image)
Dockerfile
docker-compose.yml
.dockerignore
